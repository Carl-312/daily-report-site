# ModelScope API Configuration
MODELSCOPE_API_KEY=your_token_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL=Qwen/Qwen3.5-35B-A3B
MODELSCOPE_SECONDARY_MODEL=
MODELSCOPE_MAX_OUTPUT=2000

# SiliconFlow fallback (optional)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.6

# Timezone
TIMEZONE=Asia/Shanghai

# Syft Email Digest (可选)
SYFT_WEB_APP_URL=
SYFT_SECRET_KEY=

# AGIHunt Agent API（可选；仅在显式 --agihunt on 灰度时使用）
AGIHUNT_API_KEY=

# Tavily Search API (可选)
TAVILY_API_KEY=
